<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#8D816C"
    android:id="@+id/main"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="রেজাল্ট শীট জেনারেটর"
        android:paddingTop="20dp"
        android:fontFamily="@font/sutonnymjregular"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="30dp"/>

    <ImageView
        android:id="@+id/save_image"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="10dp"
        android:src="@drawable/saveicon"
        android:contentDescription="Save Icon" />


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="শ্রেণি ও সাবজেক্ট সংখ্যা নির্বাচন করুন:"
        android:fontFamily="@font/sutonnymjregular"
        android:gravity="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:layout_marginBottom="30dp"
        android:weightSum="2">

        <Spinner
            android:id="@+id/classSpinner"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@android:drawable/btn_dropdown"/>

        <Spinner
            android:id="@+id/subjectSpinner"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@android:drawable/btn_dropdown"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnMadrasa"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="মাদ্রাসার রেজাল্ট শীট"
        android:fontFamily="@font/sutonnymjregular"
        android:layout_margin="10dp"
        android:textSize="28sp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF" />



</LinearLayout>
